# Azure OpenAI — for custom district AI analysis
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o          # or gpt-4o-mini for faster/cheaper
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional: Azure Bing Search (for web grounding when adding custom districts)
AZURE_BING_SEARCH_KEY=your_bing_key_here
